@using WEB.Models.Enuns
@using System.Security.Claims

@{
    var roleClaim = User.FindFirst(ClaimTypes.Role)?.Value;

    string roleDisplay = "";

    if (!string.IsNullOrEmpty(roleClaim) &&
        Enum.TryParse<Role>(roleClaim, out var roleEnum))
    {
        roleDisplay = roleEnum.GetDisplayName();
    }

    var fotoClaim = User.FindFirst("FotoUrl")?.Value;
    var caminhoFoto = !string.IsNullOrEmpty(fotoClaim) ? Url.Content(fotoClaim) : Url.Content("~/images/Home/foto_padrao.png");
}

<li class="nav-item dropdown">
    <a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
           data-bs-toggle="dropdown">

        <!-- Ícone + Nome (some no mobile) -->
        <span class="fs-5">👤</span>
        <span class="d-none d-md-inline">@User.Identity.Name</span>
    </a>

    <ul class="dropdown-menu dropdown-menu-end p-3 dropdown-perfil">

        <!-- 👤 PERFIL -->
        <li class="text-center mb-3">
            <img src="@caminhoFoto"
                 class="rounded-circle shadow img-perfil" />

            <div class="mt-2 fw-bold text-truncate">
                @User.Identity.Name
            </div>

            <small class="text-muted text-truncate d-block">
                @roleDisplay
            </small>
        </li>

        <li><hr class="dropdown-divider" /></li>

        <!-- ⚙️ AÇÕES -->
        <li>
            <a class="dropdown-item" asp-controller="Usuario" asp-action="Perfil">
                <i class="fa-solid fa-user me-2"></i> Meu Perfil
            </a>
        </li>

        <li>
            <a class="dropdown-item" asp-controller="Usuario" asp-action="EsqueciMinhaSenha" target="_blank">
                <i class="fa-solid fa-key me-2"></i> Alterar Senha
            </a>
        </li>

        <li><hr class="dropdown-divider" /></li>

        <!-- 🚪 SAIR -->
        <li>
            <a class="dropdown-item text-danger"
                   asp-controller="Usuario"
                   asp-action="Logout">
                <i class="fa-solid fa-right-from-bracket me-2"></i> Sair
            </a>
        </li>

    </ul>
</li>

<style>
    /* Dropdown largura adaptável */
    .dropdown-perfil {
        min-width: 220px;
        max-width: 90vw;
    }

    /* Imagem responsiva */
    .img-perfil {
        width: 80px;
        height: 80px;
        object-fit: cover;
    }
    
    @@media (max-width: 576px) {
        .dropdown-perfil {
            min-width: 180px;
            padding: 10px;
        }

        .img-perfil {
            width: 60px;
            height: 60px;
        }
    }

    /* 📱 TABLET */
    @@media (min-width: 577px) and (max-width: 992px) {
        .img-perfil {
            width: 70px;
            height: 70px;
        }
    }

    /* 💻 DESKTOP */
    @@media (min-width: 993px) {
        .img-perfil {
            width: 90px;
            height: 90px;
        }
    }
</style>
